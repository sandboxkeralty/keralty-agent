# ── GCP ──────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=keralty-agent-dev
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── Modelos ───────────────────────────────────────────────────────
USE_VERTEX_AI=false
GOOGLE_API_KEY=<ai-studio-key>
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
IMAGEN_MODEL=imagen-3.0-generate-001

# ── OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<oauth-client-id>
GOOGLE_CLIENT_SECRET=<oauth-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Feature Flags ─────────────────────────────────────────────────
USE_IAP=false
USE_AGENT_ENGINE=false
USE_RAG_ENGINE=false
USE_LIVEKIT=false
SEARCH_GROUNDING_ENABLED=false
VOICE_ENABLED=true
SLIDES_ENABLED=true
IMAGE_GEN_ENABLED=true
ADMIN_PANEL_ENABLED=false

# ── Firestore ─────────────────────────────────────────────────────
FIRESTORE_DATABASE=(default)

# ── Cloud Storage ─────────────────────────────────────────────────
GCS_BUCKET=keralty-agent-dev-artifacts

# ── App ───────────────────────────────────────────────────────────
SECRET_KEY=<32-chars-random>
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# ── Observabilidad ────────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_ENABLED=false
OTEL_SERVICE_NAME=keralty-agent-backend
ERROR_REPORTING_ENABLED=false

# ── Email — Gmail ────────────────────────────────────────────────
EMAIL_GMAIL_ENABLED=true
EMAIL_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify

# ── Email — Microsoft Outlook ─────────────────────────────────────
EMAIL_OUTLOOK_ENABLED=false
AZURE_CLIENT_ID=<azure-app-client-id>
AZURE_CLIENT_SECRET=<azure-app-client-secret>
AZURE_TENANT_ID=<azure-tenant-id>
AZURE_REDIRECT_URI=http://localhost:8000/auth/outlook/callback

# ── Email — Comportamiento ────────────────────────────────────────
EMAIL_SEND_ENABLED=true
EMAIL_TRACKING_ENABLED=true
EMAIL_TRACKING_FOLLOWUP_DAYS=3
EMAIL_MAX_THREADS=50
EMAIL_DIGEST_ENABLED=true

# ── Knowledge Base ────────────────────────────────────────────────
KB_AGENT_ENABLED=true
KB_RAG_CORPUS_ID=keralty-kb-corpus-prod
KB_GCS_BUCKET=keralty-kb-documents
KB_INDEX_ENDPOINT=
KB_MAX_RESULTS=10
